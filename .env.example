# Copy to .env.local and fill in values (never commit secrets).

# Canonical public site URL (no trailing slash). Used for metadata, sitemap, robots, and
# smart-sign QR codes (encoded URL origin should match what phones resolve in production).
# Example: https://www.yourdomain.org
NEXT_PUBLIC_SITE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bearer token for POST /api/control/v1/propose and /commit (OpenClaw / automation).
# Must match the token on the agent host. Generate: openssl rand -hex 32
INFRA24_CONTROL_SERVICE_TOKEN=

# Airtable — Oolite budget (see docs/AIRTABLE_MULTI_BASE.md)
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_BUDGET_TABLE_ID=

# Airtable — Oolite alumni (/o/oolite/alumni). Optional dedicated PAT; else alumni falls back to AIRTABLE_ALUMNI_API_KEY or AIRTABLE_API_KEY.
# AIRTABLE_OOLITE_ALUMNI_BASE_ID=
# AIRTABLE_OOLITE_ALUMNI_TABLE_ID=
# AIRTABLE_OOLITE_ALUMNI_API_KEY=
