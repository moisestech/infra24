# Copy to .env.local and fill in values (never commit secrets).

# Canonical public site URL (no trailing slash). Used for metadata, sitemap, robots, and
# smart-sign QR codes (encoded URL origin should match what phones resolve in production).
# Example: https://www.yourdomain.org
NEXT_PUBLIC_SITE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Memory Agent — OpenAI (ask, embeddings, Whisper transcribe on /o/{slug}/memory-agent)
# OPENAI_API_KEY=

# Memory Agent — ElevenLabs TTS (requires voice id; per-org override optional)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=          # From ElevenLabs voice library (voice profile URL or Voice settings)
# ELEVENLABS_VOICE_ID_OOLITE=   # Optional per-org override

# Bearer token for POST /api/control/v1/propose and /commit (OpenClaw / automation).
# Must match the token on the agent host. Generate: openssl rand -hex 32
INFRA24_CONTROL_SERVICE_TOKEN=

# Airtable — Oolite budget (see docs/AIRTABLE_MULTI_BASE.md)
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_BUDGET_TABLE_ID=

# Airtable — Oolite alumni (/o/oolite/alumni). Optional dedicated PAT; else alumni falls back to AIRTABLE_ALUMNI_API_KEY or AIRTABLE_API_KEY.
# AIRTABLE_OOLITE_ALUMNI_BASE_ID=
# AIRTABLE_OOLITE_ALUMNI_TABLE_ID=
# AIRTABLE_OOLITE_ALUMNI_API_KEY=
# Optional image column overrides (Oolite public table defaults apply when unset):
# AIRTABLE_OOLITE_ALUMNI_FIELD_FEATUREDIMAGEURL=Featured Image URL
# AIRTABLE_OOLITE_ALUMNI_FIELD_PORTRAITVERTICALURL=Portrait Vertical URL
# AIRTABLE_OOLITE_ALUMNI_FIELD_PORTRAITLANDSCAPEURL=Portrait Landscape URL
# AIRTABLE_OOLITE_ALUMNI_FIELD_ADDITIONALIMAGEURLS=Additional Image URLs
# AIRTABLE_OOLITE_ALUMNI_FIELD_IMAGEALTTEXT=Image Alt Text
# AIRTABLE_OOLITE_ALUMNI_FIELD_IMAGECREDIT=Image Credit
# AIRTABLE_OOLITE_ALUMNI_FIELD_IMAGESOURCE=Image Source
# AIRTABLE_OOLITE_ALUMNI_FIELD_IMAGEREVIEWSTATUS=Image Review Status
# AIRTABLE_OOLITE_ALUMNI_FIELD_PREFERREEDIMAGEORIENTATION=Preferred Image Orientation
# AIRTABLE_OOLITE_ALUMNI_FIELD_CLOUDINARYSOURCEBATCH=Cloudinary Folder / Source Batch

# Airtable — Soho House alumni (/o/sohohouse/alumni, memory-agent). Optional; when unset, uses Oolite alumni env (pilot).
# AIRTABLE_SOHOHOUSE_ALUMNI_BASE_ID=
# AIRTABLE_SOHOHOUSE_ALUMNI_TABLE_ID=
# ELEVENLABS_VOICE_ID_SOHOHOUSE=   # optional per-org TTS voice

# Airtable — INFRA24 CRM (DCC Network Builder + /network graph)
# Base: INFRA24 CRM (appWoYBRdklcz2RJH)
# AIRTABLE_DCC_CRM_API_KEY=
# AIRTABLE_DCC_CRM_BASE_ID=appWoYBRdklcz2RJH
# AIRTABLE_DCC_CRM_TABLE_PEOPLE=tbltHiqscY80ybsGE
# AIRTABLE_DCC_CRM_TABLE_SEED_CANDIDATES=tbl5xmCirpEoHPSbG
# AIRTABLE_DCC_CRM_TABLE_INSTITUTIONS=tblu9cIAsNSg5Khhp
# AIRTABLE_DCC_CRM_TABLE_OPPORTUNITIES=tblFdv4oI3FUXWtBl
# AIRTABLE_DCC_CRM_TABLE_INTERACTIONS=tbl4PSVbNU2G6kLVl
# AIRTABLE_DCC_CRM_TABLE_CAMPAIGNS=tblNdjser5MtVbZ4U
# AIRTABLE_DCC_CRM_TABLE_AGENT_APPROVALS=tblqw58L8pc44dmKU
# DCC_NETWORK_ADMIN_ENABLED=true   # enables /network/admin graph
# AIRTABLE_DCC_CRM_CAMPAIGN_INDEX_SEED_ID=recXXXXXXXX   # optional: link signups to event Campaign
# AIRTABLE_DCC_CRM_CAMPAIGN_EDGE_ZONES_ID=recXXXXXXXX   # optional: Seed Candidates → Related Campaign for /edgezones artists
# AIRTABLE_DCC_CRM_VIEW_SEED_EDGE_ZONES=   # optional: Airtable view scoped to Edge Zones roster (overrides text filter)
# AIRTABLE_DCC_CRM_VIEW_PEOPLE=
# AIRTABLE_DCC_CRM_VIEW_ID=   # alias: same as VIEW_PEOPLE if you only set one
# PAT scope for writes: data.records:write (Agent Approvals, DCC Index signup → People)
